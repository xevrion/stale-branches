{
  "name": "stale-branches",
  "version": "1.0.3",
  "description": "Interactive CLI to list and delete stale git branches with age, merge status, and one-shot local+remote cleanup",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "stale-branches": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "test": "vitest run",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "git",
    "branches",
    "stale",
    "cleanup",
    "cli",
    "interactive",
    "delete-branches",
    "git-cleanup"
  ],
  "author": {
    "name": "Yash Bavadiya",
    "email": "krbavadiya11@gmail.com",
    "url": "https://github.com/xevrion"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xevrion/stale-branches.git"
  },
  "homepage": "https://github.com/xevrion/stale-branches#readme",
  "bugs": {
    "url": "https://github.com/xevrion/stale-branches/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/checkbox": "^5.1.0",
    "@inquirer/confirm": "^6.0.8",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
